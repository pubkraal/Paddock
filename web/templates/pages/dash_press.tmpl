{{define "dash_press" -}}
{{template "head" .}}
<div class="shell">
  <header class="topbar">
    <div class="topbar__brand">
      <span class="logo" aria-hidden="true"></span>
      <span class="topbar__wordmark">Paddock</span>
      <span class="mono-label">Press office</span>
    </div>
    <div class="topbar__meta">
      <span class="mono-label">{{.Role}}</span>
      <span class="mono-label">Org {{.OrgID}}</span>
      <form method="post" action="/logout"><button class="btn btn--ghost" type="submit">Sign out</button></form>
    </div>
  </header>

  <main class="main">
    <div class="main__head">
      <div>
        <h1 class="main__title">Events</h1>
        <p class="muted">Stand up a race weekend from a template — entry list and accreditations imported, live in minutes.</p>
      </div>
      <a class="btn btn--primary auth__submit" style="width:auto" href="/admin/events/new">New event →</a>
    </div>

    <section class="card">
      <span class="mono-label card__label">Your events</span>
      {{if .Events}}
      <div class="list">
        {{range .Events}}
        <div class="list__row">
          <div>
            <div class="data">{{.Name}}</div>
            <div class="mono-label">Event {{.ID}}</div>
          </div>
          {{if .IsLive}}
            <span class="badge badge--green"><span class="badge__dot"></span><span class="badge__label">Live</span></span>
          {{else}}
            <span class="badge badge--neutral"><span class="badge__dot"></span><span class="badge__label">Draft</span></span>
          {{end}}
        </div>
        {{end}}
      </div>
      {{else}}
      <p class="muted">No events yet. <a href="/admin/events/new">Create your first →</a></p>
      {{end}}
    </section>
  </main>
</div>
{{template "foot" .}}
{{- end}}
