{{define "dash_sponsor" -}}
{{/* Sponsor portal. Phase 2 wires access; the value report, category-cleared
     galleries and conflict overlay land in Phase 6 — placeholders below. */}}
{{template "head" .}}
<div class="shell">
  <header class="topbar">
    <div class="topbar__brand">
      <span class="logo" aria-hidden="true"></span>
      <span class="topbar__wordmark">Paddock Partners</span>
      <span class="badge badge--blue"><span class="badge__dot"></span><span class="badge__label">Sponsor</span></span>
    </div>
    <div class="topbar__meta">
      <span class="mono-label">Org {{.OrgID}}</span>
      <form method="post" action="/logout"><input type="hidden" name="_csrf" value="{{.CSRF}}"><button class="btn btn--ghost" type="submit">Sign out</button></form>
    </div>
  </header>
  <main class="main">
    <div class="main__head"><h1 class="main__title">Sponsor value report</h1></div>
    <section class="grid grid--kpi">
      <div class="card kpi"><span class="mono-label">Cleared assets</span><span class="kpi__value stub">—</span><span class="mono-label stub">tiers · Phase 6</span></div>
      <div class="card kpi"><span class="mono-label">Your downloads</span><span class="kpi__value stub">—</span><span class="mono-label stub">delivery · Phase 8</span></div>
      <div class="card kpi"><span class="mono-label">Brand conflicts</span><span class="kpi__value stub">—</span><span class="mono-label stub">overlay · Phase 6</span></div>
    </section>
    <section class="card">
      <span class="mono-label card__label">Newly cleared in your category</span>
      <p class="muted">Category-locked galleries appear here once entitlement tiers ship (Phase 6).</p>
    </section>
  </main>
</div>
{{template "foot" .}}
{{- end}}
