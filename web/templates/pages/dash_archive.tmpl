{{define "dash_archive" -}}
{{/* Federation / archive dashboard (ASN orgs). Phase 2 wires access; the
     season archive, fixity checks and historic licences land in Phases 8/10 —
     placeholders below. */}}
{{template "head" .}}
<div class="shell">
  <header class="topbar">
    <div class="topbar__brand">
      <span class="logo" aria-hidden="true"></span>
      <span class="topbar__wordmark">Paddock Archive</span>
      <span class="badge badge--neutral"><span class="badge__dot"></span><span class="badge__label">Federation</span></span>
    </div>
    <div class="topbar__meta">
      <span class="mono-label">Org {{.OrgID}}</span>
      <form method="post" action="/logout"><input type="hidden" name="_csrf" value="{{.CSRF}}"><button class="btn btn--ghost" type="submit">Sign out</button></form>
    </div>
  </header>
  <main class="main">
    <div class="main__head"><h1 class="main__title">Season archive</h1></div>
    <section class="grid grid--kpi">
      <div class="card kpi"><span class="mono-label">Archived assets</span><span class="kpi__value stub">—</span><span class="mono-label stub">delivery · Phase 8</span></div>
      <div class="card kpi"><span class="mono-label">Championships</span><span class="kpi__value stub">—</span><span class="mono-label stub">catalog</span></div>
      <div class="card kpi"><span class="mono-label">Fixity check</span><span class="kpi__value stub">—</span><span class="mono-label stub">storage · Phase 3</span></div>
      <div class="card kpi"><span class="mono-label">Historic licences</span><span class="kpi__value stub">—</span><span class="mono-label stub">billing · Phase 9</span></div>
    </section>
    <section class="card">
      <span class="mono-label card__label">Events · preservation policy</span>
      <p class="muted">Per-season archives with format migration appear here once delivery and audit ship (Phase 8).</p>
    </section>
  </main>
</div>
{{template "foot" .}}
{{- end}}
