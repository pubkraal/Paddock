{{define "dash_teamcomms" -}}
{{/* Team-comms portal. Phase 2 wires access; own-car galleries, push-to-social
     and own-embargo land in Phases 5/7/8 — placeholders below. */}}
{{template "head" .}}
<div class="shell">
  <header class="topbar">
    <div class="topbar__brand">
      <span class="logo" aria-hidden="true"></span>
      <span class="topbar__wordmark">Paddock Team</span>
      <span class="badge badge--green"><span class="badge__dot"></span><span class="badge__label">Team comms</span></span>
    </div>
    <div class="topbar__meta">
      <span class="mono-label">Org {{.OrgID}}</span>
      <form method="post" action="/logout"><input type="hidden" name="_csrf" value="{{.CSRF}}"><button class="btn btn--ghost" type="submit">Sign out</button></form>
    </div>
  </header>
  <main class="main">
    <div class="main__head">
      <h1 class="main__title">Your cars</h1>
      <a class="btn btn--green auth__submit" style="width:auto" href="#">Push selects →</a>
    </div>
    <section class="grid grid--kpi">
      <div class="card kpi"><span class="mono-label">Our frames</span><span class="kpi__value stub">—</span><span class="mono-label stub">galleries · Phase 5</span></div>
      <div class="card kpi"><span class="mono-label">Published</span><span class="kpi__value stub">—</span><span class="mono-label stub">delivery · Phase 8</span></div>
      <div class="card kpi"><span class="mono-label">Pushed to social</span><span class="kpi__value stub">—</span><span class="mono-label stub">distribute · Phase 10</span></div>
      <div class="card kpi"><span class="mono-label">Own embargo</span><span class="kpi__value stub">—</span><span class="mono-label stub">embargo · Phase 7</span></div>
    </section>
    <section class="card">
      <span class="mono-label card__label">Own-car embargoed frames</span>
      <p class="muted">Visible to you the moment galleries and the embargo engine ship (Phases 5/7).</p>
    </section>
  </main>
</div>
{{template "foot" .}}
{{- end}}
